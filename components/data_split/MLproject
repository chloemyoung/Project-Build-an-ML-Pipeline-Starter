name: data_split

conda_env: conda.yml

entry_points:
  main:
    parameters:
      input_csv: {type: str, default: "clean_sample.csv"}
      train_artifact: {type: str, default: "train.csv"}
      test_artifact: {type: str, default: "test.csv"}
      test_size: {type: float, default: 0.2}
      random_seed: {type: int, default: 42}
    command: >
      python run.py
      --input_csv {input_csv}
      --train_artifact {train_artifact}
      --test_artifact {test_artifact}
      --test_size {test_size}
      --random_seed {random_seed}
